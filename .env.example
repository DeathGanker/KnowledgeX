# ============================================================
# KnowledgeX 环境配置示例
# ------------------------------------------------------------
# 用法：复制本文件为 .env，按需填写。
#     cp .env.example .env
# 说明：
#   - 标【必填】的不配就跑不起来；其余都有默认值，可不填。
#   - 本文件（.env.example）不含任何密钥，可以安全提交到仓库。
#   - 真实的 .env 含密钥，是否提交由你决定（私有库可提交；公开/共享前务必移除密钥）。
#   - 改完需重启后端生效（桌面端重开窗口 / 浏览器端重启服务）。
# ============================================================


# ---------- 1. 大模型（LLM + Embedding）【必填】 ----------
# 火山方舟（豆包）API Key。LLM 消化/问答 和 RAG 向量索引都用它。
ARK_API_KEY=your-ark-api-key-here

# 接入点 / 模型 / 端点 —— 这里设的值会覆盖 config.yaml 的同名项（优先级 .env > config.yaml）。
# 【必填】LLM_MODEL / EMBEDDING_MODEL：火山方舟的「推理接入点 ID」，形如 ep-2026xxxxxxxx，
#         是你账号专属的，必须换成自己的（在方舟控制台「在线推理」创建后获得）。
LLM_MODEL=your-llm-endpoint-id
EMBEDDING_MODEL=your-embedding-endpoint-id
# base_url / embedding url 一般用默认即可；换服务商（如 DeepSeek）或自建网关时才取消注释改写：
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# EMBEDDING_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal

# 多模态（可选）：上传本地图片/视频时用豆包视觉/视频接入点识别成文字（走 Files+Responses API）。
# 不填则上传图片/视频会提示"未配置视觉接入点"并跳过；PDF/Word 不受影响（本地抽取）。
# VISION_MODEL=your-vision-endpoint-id

# 若改用 DeepSeek：填下面这个，并把 config.yaml 的 llm.api_key_env 改成 DEEPSEEK_API_KEY。
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------- 2. 笔记目录 vault（可选） ----------
# 笔记数据放哪。支持 ~ 展开。代码仓库与笔记数据是分开的：仓库只装代码，笔记是你的个人数据。
# 不填时的回退：父目录已是旧 vault（含 01-笔记 等）则沿用；否则默认 ~/KnowledgeX（首次运行自动建标准目录）。
# 提示：每台机器各配各的；不要把某台机器的绝对路径提交到仓库（换机会指向不存在的路径）。
# VAULT_ROOT=~/KnowledgeX


# ---------- 3. Web 服务（可选） ----------
# 浏览器端鉴权 token：不填则首次启动自动生成并写回 .env，启动日志会打印带 token 的访问 URL。
# WEB_TOKEN=

# 监听地址 / 端口（浏览器端）。默认 0.0.0.0:7333。改端口后用新端口访问。
# WEB_HOST=0.0.0.0
# WEB_PORT=7333

# 注：桌面端（Tauri）用的 DESKTOP_LOCAL / DESKTOP_PORT 由 desktop/start-backend.sh 自动注入，
#     不要写进 .env（会被忽略/覆盖）。


# ---------- 4. GitHub（可选） ----------
# 提升 GitHub API 限额（抓取 README、导入 Stars）。不填用未认证 API，限额 60 次/小时。
# 生成：https://github.com/settings/tokens  （public repo 只读即可，需 read:user 才能导入 Stars）
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ---------- 5. 海外代理（可选） ----------
# DeepWiki 源码问答 / GitHub 抓取等海外出站需要走代理。填本地代理端口：
#   Clash 7897 / 7890、Surge 6152、V2RayU 1087 等。直连本地端口即可，不依赖系统代理开关，别用 TUN。
# 国内豆包 LLM / embedding 已硬编码绕开代理，设了也不影响它们。
# HTTPS_PROXY=http://127.0.0.1:7897
