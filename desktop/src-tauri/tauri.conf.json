{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "个人知识助手",
  "version": "0.1.0",
  "identifier": "com.knowledgebase.desktop",
  "build": {
    "beforeDevCommand": "bash start-backend.sh",
    "devUrl": "http://127.0.0.1:7346",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "个人知识助手",
        "width": 1380,
        "height": 880,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "个人知识助手桌面端",
    "longDescription": "Obsidian 个人知识库的桌面客户端：收件箱消化、全库 RAG 问答、方案规划。复用 FastAPI 后端，本地 127.0.0.1 运行。"
  }
}
